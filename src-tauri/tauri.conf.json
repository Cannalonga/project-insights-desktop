{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://127.0.0.1:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Project Insights",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "dialog": {
        "open": true,
        "save": true
      },
      "shell": {
        "open": true
      },
      "fs": {
        "readFile": true,
        "readDir": true,
        "writeFile": true,
        "createDir": true,
        "exists": true,
        "scope": [
          "$APPLOCALDATA/*",
          "$APPLOCALDATA/history/*",
          "**"
        ]
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.cannaconverter.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.png",
        "icons/icon.ico"
      ],
      "resources": [
        "resources/mpp-converter"
      ]
    },
    "windows": [
      {
        "title": "Project Insights",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  }
}