{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1510",
    "distDir": "../dist"
  },
  "package": {
    "productName": "License Admin UI",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "dialog": {
        "open": true,
        "save": true
      },
      "fs": {
        "readFile": true,
        "writeFile": true,
        "createDir": true,
        "exists": true
      },
      "shell": {
        "open": true
      }
    },
    "bundle": {
      "active": false,
      "identifier": "com.cannaconverter.licenseadminui"
    },
    "windows": [
      {
        "title": "License Admin UI",
        "width": 980,
        "height": 860,
        "resizable": true
      }
    ]
  }
}
